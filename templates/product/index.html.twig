{% extends 'base.html.twig' %}

{% block title %}Products{% endblock %}

{% block body %}

<h1>Products</h1>

<ul>
    {% for product in products %}
        <li>
            <h1>{{ product.name }}</h1>
            <p>{{ product.description }}</p>
            <p>Size: {{ product.size }}</p>
            <p>{{ product.isAvailable ? 'Available' : 'unavailable' }}</p>
        </li>
    {% endfor %}
</ul>

{% endblock %}

