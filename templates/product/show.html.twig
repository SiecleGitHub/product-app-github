{% extends 'base.html.twig' %}

{% block title %}Product{% endblock %}

{% block body %}

<h1>{{ product.name }}</h1>

<p>{{ product.description }}</p>
<p>{{ product.isAvailable ? 'available' : 'unavailable' }}</p>
<p>Size: {{ product.size }}</p>

<a href="{{ path('product_edit', {'id': product.id}) }}">Edit</a>

{% endblock %}
